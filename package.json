{
  "name": "fubar-cli",
  "version": "1.0.0",
  "description": "A discoverable smart home simulation CLI for humans and AI agents.",
  "type": "module",
  "bin": {
    "fubar": "./dist/index.js"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --target=bun --outfile=dist/index.js && chmod +x dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "smoke": "bun test tests/smoke.test.ts"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.2",
    "nanoid": "^5.1.6",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/bun": "^1.3.1",
    "typescript": "^5.9.3"
  }
}
